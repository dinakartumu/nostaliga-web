# Copy to .env.local for `vercel dev` or set these in the Vercel dashboard
# under Project Settings → Environment Variables.

# --- Spotify (required if Spotify is enabled in the iOS app) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match the redirect URI registered in the Spotify developer dashboard
# AND the value configured on the iOS client.
SPOTIFY_CLIENT_CALLBACK_URL=

# --- Strava (required if Strava is enabled in the iOS app) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# --- Trakt (required if Trakt is enabled in the iOS app) ---
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
# Must match the redirect URI registered in the Trakt app AND the value
# configured on the iOS client (currently nostaliga://trakt).
TRAKT_REDIRECT_URI=

# --- Foursquare/Swarm (required if Swarm is enabled in the iOS app) ---
FOURSQUARE_CLIENT_ID=
FOURSQUARE_CLIENT_SECRET=
# Must match the redirect URI registered in the Foursquare app AND the value
# configured on the iOS client (currently nostaliga://swarm/callback).
FOURSQUARE_REDIRECT_URI=

# --- Last.fm (required if Last.fm is enabled in the iOS app) ---
# The api_key is public (also hardcoded in the app); the shared secret must
# stay server-side. Both sign auth.getSession on /api/lastfm/session so the
# secret never ships in the app bundle (NOS-99).
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=

# --- TMDB (required if Trakt/watching is enabled in the iOS app) ---
# v4 read access token. Powers /api/tmdb/artwork and /api/tmdb/still, which
# resolve movie/show posters server-side so the token never ships in the app
# and clients that can't reach api.themoviedb.org still get posters (NOS-94).
TMDB_API_KEY=
# Optional: if set, the TMDB artwork proxy requires a matching `x-nostaliga-app`
# header so the key/quota isn't open to anonymous abuse. The iOS client must
# send the same value. Leave unset to allow unauthenticated calls.
APP_PROXY_SECRET=

# --- Encryption (optional but recommended) ---
# If set, the Spotify refresh_token returned by /api/spotify/token is
# encrypted with aes-256-cbc before being sent to the client, and decrypted
# on /api/spotify/refresh_token. Must stay constant for the lifetime of
# tokens already issued — rotating the secret invalidates existing refresh
# tokens stored on users' devices.
ENCRYPTION_SECRET=
