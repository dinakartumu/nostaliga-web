---
import Layout from "../layouts/Layout.astro";

// Feature screenshots live in public/screenshots/ (generated from fixture mode).
const memories = [
  {
    img: "/screenshots/now-playing.jpg",
    eyebrow: "Music",
    title: "Your soundtrack, remembered.",
    body: "Every track you played — when, where, and how many times. The score to your life, back on the timeline.",
  },
  {
    img: "/screenshots/photos.jpg",
    eyebrow: "Photos",
    title: "The photos you forgot you took.",
    body: "Your camera roll, matched on-device to the moment and the music that was playing.",
  },
  {
    img: "/screenshots/activity.jpg",
    eyebrow: "Activities",
    title: "Every mile has a soundtrack.",
    body: "Rides, runs and hikes drawn on the map — with the songs that carried you through them.",
  },
  {
    img: "/screenshots/places.jpg",
    eyebrow: "Places",
    title: "The places you kept going back to.",
    body: "Check-ins remember the coffee shops, libraries and streets that quietly became yours.",
  },
  {
    img: "/screenshots/social.jpg",
    eyebrow: "Posts",
    title: "Your cringe, preserved.",
    body: "The tweets and posts you'd rather forget — right where you left them, exactly as awkward.",
  },
];

const life = [
  {
    img: "/screenshots/calendar.jpg",
    eyebrow: "Calendar",
    title: "The plans you actually kept.",
    body: "Dinners, reservations and events — who was invited, and who actually showed up.",
  },
  {
    img: "/screenshots/tv.jpg",
    eyebrow: "Movies & TV",
    title: "Every finale. Every letdown.",
    body: "What you watched, the night you finished it, and the tweet you fired off about the ending.",
  },
];
---

<Layout title="Nostaliga — a timeline of everything you've done" path="/" wide>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-x-0 -top-40 mx-auto h-[36rem] max-w-3xl rounded-full opacity-40 blur-3xl"
      style="background: radial-gradient(closest-side, rgba(224,184,88,0.35), transparent 70%);"
      aria-hidden="true"
    >
    </div>
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-8 text-center sm:pt-24">
      <p
        class="mb-6 text-xs uppercase tracking-[0.28em] text-[color:var(--color-ink-dim)]"
      >
        Coming soon to iPhone
      </p>
      <h1
        class="mx-auto max-w-4xl text-5xl leading-[1.05] sm:text-7xl md:text-[5.5rem]"
        style="font-family: var(--font-display);"
      >
        Everything you've done, on one timeline.
      </h1>
      <p
        class="mx-auto mt-8 max-w-2xl text-lg text-[color:var(--color-ink-dim)] sm:text-xl"
      >
        Nostaliga quietly stitches your music, photos, workouts, places, posts
        and screens into a single scrollable memory — and keeps every bit of it
        on your device.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <a
          href="mailto:dinakartumu@gmail.com?subject=Nostaliga%20TestFlight"
          class="rounded-full bg-[color:var(--color-accent)] px-7 py-3 text-sm font-medium text-[color:var(--color-bg)] hover:no-underline hover:brightness-110"
        >
          Request TestFlight access
        </a>
        <a
          href="/privacy"
          class="rounded-full border border-white/15 px-7 py-3 text-sm text-[color:var(--color-ink)] hover:no-underline hover:border-white/40"
        >
          How your data is handled
        </a>
      </div>
    </div>

    <div class="mx-auto mt-6 flex max-w-6xl justify-center px-6 pb-8">
      <img
        src="/screenshots/photos.jpg"
        alt="The Nostaliga now-playing timeline showing a memory from years past"
        width="300"
        loading="eager"
        class="w-[260px] rounded-[2.4rem] border border-white/10 shadow-[0_40px_120px_-20px_rgba(0,0,0,0.8)] sm:w-[300px]"
      />
    </div>
  </section>

  <!-- Statement -->
  <section class="border-t border-white/5 py-24">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2
        class="text-3xl leading-tight sm:text-5xl"
        style="font-family: var(--font-display);"
      >
        You already made the memories.
        <span class="text-[color:var(--color-ink-dim)]"
          >Nostaliga just brings them back.</span
        >
      </h2>
    </div>
  </section>

  <!-- Band 1: Everything you did -->
  <section class="pt-12">
    <div class="mx-auto max-w-6xl px-6">
      <p
        class="text-xs uppercase tracking-[0.28em] text-[color:var(--color-accent)]"
      >
        Everything you did
      </p>
    </div>
    {
      memories.map((f, i) => (
        <div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
          <div
            class:list={[
              "grid items-center gap-10 md:grid-cols-2 md:gap-16",
              i % 2 === 1 && "md:[&>figure]:order-first",
            ]}
          >
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-[color:var(--color-ink-dim)]">
                {f.eyebrow}
              </p>
              <h3
                class="mt-3 text-3xl leading-tight sm:text-4xl"
                style="font-family: var(--font-display);"
              >
                {f.title}
              </h3>
              <p class="mt-5 max-w-md text-lg text-[color:var(--color-ink-dim)]">
                {f.body}
              </p>
            </div>
            <figure class="relative flex justify-center">
              <div
                class="pointer-events-none absolute inset-x-0 top-1/2 -z-10 mx-auto h-72 w-72 -translate-y-1/2 rounded-full opacity-70 blur-[90px]"
                style="background: radial-gradient(closest-side, rgba(224,184,88,0.16), transparent 72%);"
                aria-hidden="true"
              >
              </div>
              <img
                src={f.img}
                alt={f.title}
                width="280"
                loading="lazy"
                class="relative w-[230px] rounded-[2.2rem] border border-white/10 shadow-[0_30px_90px_-25px_rgba(0,0,0,0.8)] sm:w-[270px]"
              />
            </figure>
          </div>
        </div>
      ))
    }
  </section>

  <!-- Band 2: Everything you loved -->
  <section class="border-t border-white/5 pt-16">
    <div class="mx-auto max-w-6xl px-6">
      <p
        class="text-xs uppercase tracking-[0.28em] text-[color:var(--color-accent)]"
      >
        Everything you loved
      </p>
    </div>
    {
      life.map((f, i) => (
        <div class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
          <div
            class:list={[
              "grid items-center gap-10 md:grid-cols-2 md:gap-16",
              i % 2 === 1 && "md:[&>figure]:order-first",
            ]}
          >
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-[color:var(--color-ink-dim)]">
                {f.eyebrow}
              </p>
              <h3
                class="mt-3 text-3xl leading-tight sm:text-4xl"
                style="font-family: var(--font-display);"
              >
                {f.title}
              </h3>
              <p class="mt-5 max-w-md text-lg text-[color:var(--color-ink-dim)]">
                {f.body}
              </p>
            </div>
            <figure class="relative flex justify-center">
              <div
                class="pointer-events-none absolute inset-x-0 top-1/2 -z-10 mx-auto h-72 w-72 -translate-y-1/2 rounded-full opacity-70 blur-[90px]"
                style="background: radial-gradient(closest-side, rgba(224,184,88,0.16), transparent 72%);"
                aria-hidden="true"
              >
              </div>
              <img
                src={f.img}
                alt={f.title}
                width="280"
                loading="lazy"
                class="relative w-[230px] rounded-[2.2rem] border border-white/10 shadow-[0_30px_90px_-25px_rgba(0,0,0,0.8)] sm:w-[270px]"
              />
            </figure>
          </div>
        </div>
      ))
    }
  </section>

  <!-- Privacy -->
  <section class="border-t border-white/5 py-24">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="text-3xl sm:text-5xl" style="font-family: var(--font-display);">
        Private by design.
      </h2>
      <p class="mt-5 max-w-2xl text-lg text-[color:var(--color-ink-dim)]">
        Your whole life is on this timeline — so none of it leaves your phone.
      </p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-white/5 bg-[color:var(--color-bg-soft)] p-6">
          <h3 class="text-lg text-[color:var(--color-ink)]">On-device matching</h3>
          <p class="mt-2 text-[color:var(--color-ink-dim)]">
            Photos, music and health data are correlated locally — never uploaded.
          </p>
        </div>
        <div class="rounded-2xl border border-white/5 bg-[color:var(--color-bg-soft)] p-6">
          <h3 class="text-lg text-[color:var(--color-ink)]">Keychain-only tokens</h3>
          <p class="mt-2 text-[color:var(--color-ink-dim)]">
            Every third-party OAuth token stays in the iOS Keychain on your device.
          </p>
        </div>
        <div class="rounded-2xl border border-white/5 bg-[color:var(--color-bg-soft)] p-6">
          <h3 class="text-lg text-[color:var(--color-ink)]">No tracking</h3>
          <p class="mt-2 text-[color:var(--color-ink-dim)]">
            No analytics SDKs, no advertising identifier, no third-party trackers.
          </p>
        </div>
        <div class="rounded-2xl border border-white/5 bg-[color:var(--color-bg-soft)] p-6">
          <h3 class="text-lg text-[color:var(--color-ink)]">You're in control</h3>
          <p class="mt-2 text-[color:var(--color-ink-dim)]">
            Disconnect any service or delete its imported history anytime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="border-t border-white/5 py-28">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2
        class="text-4xl leading-tight sm:text-6xl"
        style="font-family: var(--font-display);"
      >
        Relive it all.
      </h2>
      <div class="mt-10">
        <a
          href="mailto:dinakartumu@gmail.com?subject=Nostaliga%20TestFlight"
          class="rounded-full bg-[color:var(--color-accent)] px-8 py-3.5 text-sm font-medium text-[color:var(--color-bg)] hover:no-underline hover:brightness-110"
        >
          Request TestFlight access
        </a>
      </div>
    </div>
  </section>
</Layout>
