---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Support — Nostaliga"
  description="Getting help with Nostaliga: contact, FAQs, and how to reset the app."
  path="/support"
>
  <article class="pt-16">
    <h1 class="text-4xl sm:text-5xl" style="font-family: var(--font-display);">
      Support
    </h1>
    <p class="mt-6 max-w-2xl text-[color:var(--color-ink-dim)]">
      The fastest way to get help is email. Include your iOS version, the
      integration you were using, and a short description of what happened.
    </p>

    <div class="mt-10 rounded-2xl border border-white/10 bg-[color:var(--color-bg-soft)] p-6">
      <h2 class="text-2xl" style="font-family: var(--font-display);">Email</h2>
      <p class="mt-2 text-[color:var(--color-ink-dim)]">
        <a href="mailto:dinakartumu@gmail.com?subject=Nostaliga%20support"
          >dinakartumu@gmail.com</a
        >
      </p>
      <p class="mt-2 text-sm text-[color:var(--color-ink-dim)]">
        Usual response time: within 2 business days.
      </p>
    </div>

    <h2 class="mt-16 text-2xl" style="font-family: var(--font-display);">
      Frequently asked
    </h2>
    <p class="mt-6 max-w-2xl text-[color:var(--color-ink-dim)]">
      Common questions — connecting services, importing archives, why something
      isn't showing up, resetting the app, and privacy — are answered on the
      <a href="/faq">FAQ page</a>.
    </p>
  </article>
</Layout>
